{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":semanticCommits",
    ":maintainLockFilesWeekly"
  ],
  "automerge": true,
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "description": "Review major updates manually instead of auto-merging",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
