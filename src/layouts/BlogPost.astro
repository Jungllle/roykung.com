---
import type { CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import "../styles/global.css";

type NavLink = { href: string; title: string } | null;
type Props = CollectionEntry<"blog">["data"] & {
  prevPost?: NavLink;
  nextPost?: NavLink;
};

const {
  title,
  description,
  pubDate,
  heroImage,
  prevPost = null,
  nextPost = null,
} = Astro.props;

const shareUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const shareText = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(shareUrl);

const shareLinks = [
  {
    label: "分享到 X",
    href: `https://twitter.com/intent/tweet?text=${shareText}&url=${encodedUrl}`,
    path: "M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84",
  },
  {
    label: "分享到 Facebook",
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
    path: "M20 10c0-5.523-4.477-10-10-10S0 4.477 0 10c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V10h2.54V7.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V10h2.773l-.443 2.89h-2.33v6.988C16.343 19.128 20 14.991 20 10z",
  },
];
---

<Layout
  title={title}
  description={description}
  type="article"
  publishedDate={pubDate}
  image={heroImage ?? "/profile.jpeg"}
>
  <article class="mx-auto max-w-3xl">
    <header class="mb-10">
      <a
        href="/blog"
        class="inline-flex items-center text-sm font-medium text-gray-500 transition-colors hover:text-gray-900"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="mr-1.5 h-4 w-4"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        所有文章
      </a>

      <h1
        class="mt-6 text-pretty text-3xl font-bold leading-tight tracking-tight text-gray-900 sm:text-4xl"
      >
        {title}
      </h1>

      <div class="mt-4 flex items-center gap-x-3 text-sm text-gray-500">
        <FormattedDate date={pubDate} />
      </div>

      {
        description && description !== title && (
          <p class="mt-5 text-lg leading-relaxed text-gray-600">
            {description}
          </p>
        )
      }
    </header>

    {
      heroImage && (
        <img
          src={heroImage}
          alt={`Cover image for ${title}`}
          class="mb-10 h-auto w-full rounded-xl object-cover shadow-md"
        />
      )
    }

    <div
      class="prose prose-lg prose-gray max-w-none prose-headings:font-semibold prose-a:text-blue-600 hover:prose-a:text-blue-800 prose-img:rounded-xl"
    >
      <slot />
    </div>

    {
      (prevPost || nextPost) && (
        <nav class="mt-16 grid gap-4 border-t border-gray-200 pt-8 sm:grid-cols-2">
          {prevPost ? (
            <a
              href={prevPost.href}
              class="group flex flex-col rounded-xl border border-gray-200 p-4 transition-colors hover:border-gray-300 hover:bg-gray-50"
            >
              <span class="text-xs font-medium uppercase tracking-wide text-gray-400">
                ← 上一篇
              </span>
              <span class="mt-1 font-semibold text-gray-900 group-hover:text-blue-700">
                {prevPost.title}
              </span>
            </a>
          ) : (
            <span class="hidden sm:block" />
          )}
          {nextPost && (
            <a
              href={nextPost.href}
              class="group flex flex-col rounded-xl border border-gray-200 p-4 text-right transition-colors hover:border-gray-300 hover:bg-gray-50"
            >
              <span class="text-xs font-medium uppercase tracking-wide text-gray-400">
                下一篇 →
              </span>
              <span class="mt-1 font-semibold text-gray-900 group-hover:text-blue-700">
                {nextPost.title}
              </span>
            </a>
          )}
        </nav>
      )
    }

    <footer
      class="mt-16 flex flex-col gap-y-4 border-t border-gray-200 pt-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <a
        href="/blog"
        class="inline-flex items-center text-sm font-medium text-gray-600 transition-colors hover:text-gray-900"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="mr-1.5 h-4 w-4"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        返回文章列表
      </a>
      <div class="flex items-center gap-x-2">
        <span class="mr-1 text-sm text-gray-400">分享</span>
        {
          shareLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="rounded-full p-2 text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-700"
            >
              <svg
                class="h-5 w-5"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d={link.path} />
              </svg>
            </a>
          ))
        }
      </div>
    </footer>
  </article>
</Layout>
